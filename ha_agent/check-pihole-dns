#!/usr/bin/env python3
import json
import socket
import sqlite3
import struct
import subprocess
import sys
from pathlib import Path

ROOT = Path("/var/lib/kaya-ha-agent")
HELPER = "/usr/lib/kaya-ha-agent/kaya_ha_failover_helper.py"

if sys.argv[1:] not in ([], ["--observe"]):
    raise SystemExit(2)

query_id = 0x4B41
packet = struct.pack("!HHHHHH", query_id, 0x0100, 1, 0, 0, 0) + b"\x02pi\x04hole\x00" + struct.pack("!HH", 1, 1)
try:
    with socket.socket(socket.AF_INET, socket.SOCK_DGRAM) as client:
        client.settimeout(2); client.sendto(packet, ("127.0.0.1", 53)); response, _ = client.recvfrom(512)
    healthy = len(response) >= 12 and struct.unpack("!H", response[:2])[0] == query_id
except (OSError, TimeoutError):
    healthy = False

try:
    with sqlite3.connect(ROOT / "state.sqlite3") as db:
        db.execute("CREATE TABLE IF NOT EXISTS state (key TEXT PRIMARY KEY, value TEXT NOT NULL)")
        def get(key, default=None):
            row = db.execute("SELECT value FROM state WHERE key=?", (key,)).fetchone()
            return json.loads(row[0]) if row else default
        if len(sys.argv) == 1:
            failures = 0 if healthy else int(get("dns_consecutive_failures", 0)) + 1
            db.execute("INSERT INTO state(key,value) VALUES('dns_consecutive_failures',?) ON CONFLICT(key) DO UPDATE SET value=excluded.value", (json.dumps(failures),))
            db.commit()
            if failures >= 3 and get("automatic_failover", False) and get("dhcp_managed", False) and get("vip_owned", False):
                generation = int(get("keepalived_generation", 0))
                subprocess.run(["sudo", "-n", HELPER, "automatic-demote", str(generation)], capture_output=True, timeout=20, check=False)
except (OSError, sqlite3.Error, ValueError):
    pass
raise SystemExit(0 if healthy else 1)
