APP_NAME=HomeLab
APP_ENV=production
BASE_URL=http://localhost:8080
# Only set this if your reverse proxy serves HomeLab from a subpath, for example /homelab.
ROOT_PATH=

# Generate fresh values and paste them below:
#   docker run --rm ghcr.io/antybubbs/homelab:latest python scripts/generate_secrets.py
# Or, from a local checkout:
#   python scripts/generate_secrets.py
# SECRET_KEY=change-this-secret-key
# ENCRYPTION_KEY=change-this-fernet-key

ADMIN_EMAIL=admin@example.local
ADMIN_PASSWORD=change-me-now

DATABASE_URL=sqlite:////app/data/homelab.db
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_MB=25
# Comma-separated extra hostnames or IPs users browse to.
# BASE_URL is also trusted automatically.
# Examples:
# ALLOWED_HOSTS=homelab.example.com
# ALLOWED_HOSTS=192.168.1.50,homelab.home.arpa
ALLOWED_HOSTS=

# Set to true after serving HomeLab through HTTPS.
SESSION_COOKIE_SECURE=false

# Reverse proxy support. Use * when HomeLab is only reachable through your trusted proxy/Docker network.
FORWARDED_ALLOW_IPS=*

# Used by the sidebar version check link.
GITHUB_REPO=antybubbs/HomeLab

# Version Check Interval for sidebar display
VERSION_CHECK_INTERVAL_SECONDS=1800

# Optional: if set, these override Remote Manager Settings for the embedded Guacamole bridge.
# Otherwise configure guacd from System Settings > Remote Manager Settings.
GUACD_HOST=
GUACD_PORT=

# Used by docker-compose.prod.yml when deploying a published image.
HOMELAB_IMAGE=ghcr.io/antybubbs/homelab:latest
# Development/test server only:
# HOMELAB_IMAGE=ghcr.io/antybubbs/homelab:dev0.15.1
HOMELAB_PORT=8080
