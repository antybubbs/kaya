# Example: forg.app.strubens.uk/cheezy/keyvault:latest
KEYVAULT_IMAGE=forg.app.strubens.uk/cheezy/keyvault:latest
KEYVAULT_PORT=8080

APP_NAME=KeyVault
APP_ENV=production
BASE_URL=https://keyvault.example.local

# Generate these with: python scripts/generate_secrets.py
SECRET_KEY=replace-with-a-long-random-secret
ENCRYPTION_KEY=replace-with-a-fernet-key

# First boot admin account
ADMIN_EMAIL=admin@example.local
ADMIN_PASSWORD=replace-with-a-strong-password

DATABASE_URL=sqlite:////app/data/keyvault.db
UPLOAD_DIR=/app/uploads
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=lax
