# Example: ghcr.io/antybubbs/homelab:latest
HOMELAB_IMAGE=ghcr.io/antybubbs/homelab:latest
# Development/test server only:
# HOMELAB_IMAGE=ghcr.io/antybubbs/homelab:dev0.15.1
HOMELAB_PORT=8080

APP_NAME=HomeLab
APP_ENV=production
BASE_URL=https://homelab.example.local

# Generate these with: python scripts/generate_secrets.py
SECRET_KEY=replace-with-a-long-random-secret
ENCRYPTION_KEY=replace-with-a-fernet-key

# First boot admin account
ADMIN_EMAIL=admin@example.local
ADMIN_PASSWORD=replace-with-a-strong-password

DATABASE_URL=sqlite:////app/data/homelab.db
UPLOAD_DIR=/app/uploads
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=lax

# Optional: if set, these override Remote Manager Settings for the embedded Guacamole bridge.
GUACD_HOST=
GUACD_PORT=
