APP_NAME=KeyVault
APP_ENV=production
BASE_URL=http://localhost:8080

# Generate fresh values with:
#   python scripts/generate_secrets.py
SECRET_KEY=change-this-secret-key
ENCRYPTION_KEY=change-this-fernet-key

ADMIN_EMAIL=admin@example.local
ADMIN_PASSWORD=change-me-now

DATABASE_URL=sqlite:////app/data/keyvault.db
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_MB=25

# Set to true after serving KeyVault through HTTPS.
SESSION_COOKIE_SECURE=false

# Used by docker-compose.prod.yml when deploying a published image.
KEYVAULT_IMAGE=forg.app.strubens.uk/cheezy/keyvault:latest
KEYVAULT_PORT=8080
