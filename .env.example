APP_NAME=KeyVault
APP_ENV=production
BASE_URL=http://localhost:8080
# Only set this if your reverse proxy serves KeyVault from a subpath, for example /keyvault.
ROOT_PATH=

# Generate fresh values and paste them below:
#   docker run --rm ghcr.io/antybubbs/keyvault:latest python scripts/generate_secrets.py
# Or, from a local checkout:
#   python scripts/generate_secrets.py
SECRET_KEY=change-this-secret-key
ENCRYPTION_KEY=change-this-fernet-key

ADMIN_EMAIL=admin@example.local
ADMIN_PASSWORD=change-me-now

DATABASE_URL=sqlite:////app/data/keyvault.db
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_MB=25
# Comma-separated extra hostnames or IPs users browse to.
# BASE_URL is also trusted automatically.
# Examples:
# ALLOWED_HOSTS=keyvault.example.com
# ALLOWED_HOSTS=192.168.1.50,keyvault.home.arpa
ALLOWED_HOSTS=

# Set to true after serving KeyVault through HTTPS.
SESSION_COOKIE_SECURE=false

# Reverse proxy support. Use * when KeyVault is only reachable through your trusted proxy/Docker network.
FORWARDED_ALLOW_IPS=*

# Used by docker-compose.prod.yml when deploying a published image.
KEYVAULT_IMAGE=ghcr.io/antybubbs/keyvault:latest
KEYVAULT_PORT=8080
